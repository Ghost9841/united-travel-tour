// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or "mysql", "sqlite", "mongodb"
  url      = env("DIRECT_URL")
}

model Travel {
  id            Int      @id @default(autoincrement())
  title         String
  location      String
  description   String   @db.Text
  price         Float
  originalPrice Float
  duration      String
  rating        Float    @default(0)
  reviews       Int      @default(0)
  image         String
  category      String
  groupSize     String   @map("group_size")
  
  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("travels")
}

model ExplorePage {
  id              Int      @id @default(autoincrement())
  title           String
  description     String   @db.Text
  location        String
  price           Float
  discountedPrice Float
  duration        String   @default("5 Days / 4 Nights")
  status          String   @default("active") // 'active' or 'draft'
  rating          Float    @default(0)
  views           Int      @default(0)
  likes           Int      @default(0)
  image           String
  category        String

  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("explorepage")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  color       String?  // For UI colors

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categories")
}

model Hotel {
  id            Int      @id @default(autoincrement())
  name          String
  location      String
  description   String   @db.Text
  pricePerNight Float
  originalPrice Float
  rating        Float    @default(4.0)
  reviews       Int      @default(0)
  images        String[] // Array of image URLs
  amenities     String[] // Array of amenity strings
  roomType      String
  capacity      String
  status        String   @default("active") // 'active' or 'draft'

  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("hotels")
}

model Destination {
  id            Int      @id @default(autoincrement())
  name          String
  country       String
  description   String   @db.Text
  image         String
  price         Float
  originalPrice Float
  rating        Float    @default(4.0)
  reviews       Int      @default(0)
  duration      String
  groupSize     String   @map("group_size")
  category      String
  status        String   @default("active") // 'active' or 'draft'
  featured      Boolean  @default(false)
  views         Int      @default(0)
  likes         Int      @default(0)

  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("destinations")
}

model TrendingRoute {
  id             Int      @id @default(autoincrement())
  from           String
  to             String
  back           String   @default("")
  price          Float
  currency       String   @default("£")
  image          String   @default("")
  airline        String
  travelClass    String   @default("Economy") @map("travel_class")
  checkinBaggage String   @map("checkin_baggage")
  cabinBaggage   String   @map("cabin_baggage")
  baseFare       Float    @map("base_fare")
  status         String   @default("active") // 'active' or 'draft'
  order          Int      @default(0)

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  @@map("trending_routes")
}

model SpecialOffer {
  id              Int      @id @default(autoincrement())
  title           String
  description     String   @db.Text
  location        String   @default("")
  price           Float    @default(0)
  discountedPrice Float    @default(0)  @map("discounted_price")
  image           String   @default("")
  rating          Float    @default(5)
  status          String   @default("active") // 'active' or 'draft'
  views           Int      @default(0)
  likes           Int      @default(0)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  @@map("special_offers")
}
model CarouselImage {
  id        Int      @id @default(autoincrement())
  src       String
  alt       String   @default("")
  order     Int      @default(0)   // controls display order
  status    String   @default("active") // 'active' or 'draft'

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("carousel_images")
}

model LandingHeroCarouselImage {
  id  Int   @id @default(autoincrement())
  src String
  alt String @default("")
  order Int  @default(0)
  status String @default("active")

   createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("herocarousel_images")
}